{
  "name": "GoddessClaw",
  "short_name": "GoddessClaw",
  "description": "AI coding assistant with full filesystem access",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0d1117",
  "theme_color": "#7c3aed",
  "orientation": "any",
  "categories": ["developer", "productivity"],
  "icons": [
    {
      "src": "/claw-icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/*": [".txt", ".md", ".json", ".js", ".ts", ".tsx", ".jsx", ".py", ".rs", ".go", ".html", ".css", ".yml", ".yaml", ".toml"]
      }
    }
  ]
}
