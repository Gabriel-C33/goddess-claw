# GoddessClaw - Environment Variables
# Copy this file to .env and fill in your API keys

# ── Cloud AI Providers (optional — add any you want to use) ──
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...
# MOONSHOT_API_KEY=sk-...

# ── Ollama (local models) ──
# OLLAMA_BASE_URL=http://localhost:11434

# ── Default model (falls back to first available) ──
# GODDESS_CLAW_MODEL=qwen2.5-coder:7b
